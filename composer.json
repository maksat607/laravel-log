{
    "name": "maksatsaparbekov/laravel-log",
    "description": "A simple Laravel package to view and manage log files",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Maksat Saparbekov",
            "email": "maksat@example.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "illuminate/view": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Maksatsaparbekov\\LaravelLog\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Maksatsaparbekov\\LaravelLog\\LaravelLogServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
